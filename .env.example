# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Kubernetes
KUBECONFIG=~/.kube/config
DEFAULT_NAMESPACE=default
DEFAULT_CLUSTER=production

# Vector DB
VECTORDB_PATH=./data/vectordb
VECTORDB_COLLECTION=k8s_logs

# Workflow
STREAMING_ENABLED=true
DEBUG_MODE=false
MAX_RETRIES=3
TIMEOUT_SECONDS=300

# vEPC Configuration
VEPC_VECTORDB_PATH=./data/vepc_vectordb
VEPC_VECTORDB_COLLECTION=vepc_docs
VEPC_MAX_VALIDATION_RETRIES=2
VEPC_CLI_TIMEOUT=30
VEPC_STREAMING_ENABLED=true
VEPC_DEBUG_MODE=false
